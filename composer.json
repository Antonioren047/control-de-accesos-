{
  "name": "vigilancia/control-de-accesos",
  "description": "Base técnica del Sistema de Vigilancia",
  "type": "project",
  "require": {
    "dompdf/dompdf": "^2.0",
    "endroid/qr-code": "^5.0",
    "php": "^8.1",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "Vigilancia\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vigilancia\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "scripts": {
    "test": "phpunit",
    "check": "php scripts/check_requirements.php",
    "migrate": "php scripts/migrate.php",
    "seed": "php scripts/seed.php"
  }
}
